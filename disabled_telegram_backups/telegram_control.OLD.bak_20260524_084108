                    state["paused"] = False
                    save_state(state)
                    send(
                        token,
                        chat_id,
                        "🚨 CLOSE ALL activated\nBuying disabled.\nBot will attempt to close all positions.",
                    )


                
                elif text == "/history":
                    try:
                        import json

