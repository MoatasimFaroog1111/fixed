PENDING_FILE = BASE_DIR / "pending_order.json"

SYMBOLS = {
    "silver": {
        "security_id": "AGXLN",
        "currency": "USD",
        "name": "Silver",
        "icon": "🥈",
        "log": BASE_DIR / "bot_silver.log",
