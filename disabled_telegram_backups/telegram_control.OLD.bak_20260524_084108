        "log": BASE_DIR / "bot_palladium.log",
        "max_qty": 0.1,
    },
}

STOP_LOSS_PCT = 0.018
TAKE_PROFIT_PCT = 0.014


def load_env():
    env = {}
    for line in ENV_FILE.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if line and not line.startswith("#") and "=" in line:
            k, v = line.split("=", 1)
            env[k.strip()] = v.strip()
    return env


def load_state():
    default = {
        "paused": False,
        "allow_buy": True,
        "allow_sell": True,
        "silver_enabled": True,
        "palladium_enabled": True,
        "stop_loss_enabled": True,
        "emergency_close_all": False,
        "paused_after_close_all": True,
    }
    if CONTROL_FILE.exists():
        try:
            default.update(json.loads(CONTROL_FILE.read_text(encoding="utf-8")))
        except Exception:
            pass
    return default


def save_state(state):
    CONTROL_FILE.write_text(json.dumps(state, indent=2), encoding="utf-8")


def send(token, chat_id, text):
    requests.post(
        f"https://api.telegram.org/bot{token}/sendMessage",
        json={"chat_id": chat_id, "text": text},
        timeout=20,
    )


def get_updates(token, offset=None):
    params = {"timeout": 30}
    if offset is not None:
        params["offset"] = offset
    r = requests.get(
        f"https://api.telegram.org/bot{token}/getUpdates",
        params=params,
        timeout=40,
    )
    r.raise_for_status()
    return r.json()


def latest_price_from_log(symbol_key):
    log_file = SYMBOLS[symbol_key]["log"]
    if not log_file.exists():
        return None

    lines = log_file.read_text(
        encoding="utf-8",
        errors="ignore"
    ).splitlines()[-500:]

    price_re = re.compile(
        r"PRICE \| bid=([0-9.]+) ask=([0-9.]+) mid=([0-9.]+)"
    )

    for line in reversed(lines):
        m = price_re.search(line)
        if m:
            bid = float(m.group(1))
            ask = float(m.group(2))
            mid = float(m.group(3))
            return {"bid": bid, "ask": ask, "mid": mid}

    return None


def estimate_preview(action, symbol_key, qty, limit_price):
    symbol = SYMBOLS[symbol_key]
    market = latest_price_from_log(symbol_key)

    total = qty * limit_price

    if action == "B":
        sl = limit_price * (1 - STOP_LOSS_PCT)
        tp = limit_price * (1 + TAKE_PROFIT_PCT)
        loss_usd = qty * (limit_price - sl)
        profit_usd = qty * (tp - limit_price)
    else:
        sl = limit_price * (1 + STOP_LOSS_PCT)
        tp = limit_price * (1 - TAKE_PROFIT_PCT)
        loss_usd = qty * (sl - limit_price)
        profit_usd = qty * (limit_price - tp)

    spread_text = "Spread: غير متاح من آخر لوق"
    warning = "⚠️ لا يوجد سعر سوق حديث كافٍ للحكم على السبريد."

    if market:
        bid = market["bid"]
        ask = market["ask"]
        mid = market["mid"]
        spread = ask - bid
        spread_pct = (spread / bid) if bid else 0

        spread_text = (
            f"Bid: {bid:,.2f}\n"
            f"Ask: {ask:,.2f}\n"
            f"Mid: {mid:,.2f}\n"
            f"Spread: {spread:,.2f} ({spread_pct:.2%})"
        )

        if spread_pct <= 0.006:
            warning = "✅ السبريد ممتاز/مقبول."
        elif spread_pct <= 0.015:
            warning = "⚠️ السبريد متوسط، انتبه."
        else:
            warning = "🚨 السبريد عالي جدًا، الصفقة خطرة."

    side_text = "شراء" if action == "B" else "بيع"

    return (
        f"📋 Order Preview\n\n"
        f"{symbol['icon']} {side_text} {symbol['name']}\n"
        f"Security: {symbol['security_id']}/{symbol['currency']}\n"
        f"Qty: {qty:.3f} kg\n"
        f"Limit Price: {limit_price:,.2f}\n"
        f"Estimated Value: ${total:,.2f}\n\n"
        f"📈 Market Snapshot\n"
        f"{spread_text}\n\n"
        f"🛡️ Risk Estimate\n"
        f"Stop Loss @ {STOP_LOSS_PCT:.1%}: {sl:,.2f}\n"
        f"Expected Loss: -${loss_usd:,.2f}\n"
        f"Take Profit @ {TAKE_PROFIT_PCT:.1%}: {tp:,.2f}\n"
        f"Expected Profit: +${profit_usd:,.2f}\n\n"
        f"{warning}\n\n"
        f"للتنفيذ أرسل:\n"
        f"/confirm_order\n\n"
        f"للإلغاء أرسل:\n"
        f"/cancel_order"
    )


def save_pending(order):
    PENDING_FILE.write_text(json.dumps(order, indent=2), encoding="utf-8")


def load_pending():
    if not PENDING_FILE.exists():
        return None
    try:
        return json.loads(PENDING_FILE.read_text(encoding="utf-8"))
    except Exception:
        return None


def clear_pending():
    if PENDING_FILE.exists():
        PENDING_FILE.unlink()


def parse_manual_order(text):
    parts = text.split()

    if len(parts) != 3:
        return None, "الصيغة الصحيحة: /buy_silver 0.005 2420"

    cmd, qty_s, price_s = parts

    mapping = {
        "/buy_silver": ("B", "silver"),
        "/sell_silver": ("S", "silver"),
        "/buy_palladium": ("B", "palladium"),
        "/sell_palladium": ("S", "palladium"),
    }

    if cmd not in mapping:
        return None, "أمر غير معروف."

    try:
        qty = float(qty_s)
        price = float(price_s)
    except ValueError:
        return None, "الكمية والسعر يجب أن يكونا أرقامًا."

    if qty <= 0 or price <= 0:
        return None, "الكمية والسعر يجب أن يكونا أكبر من صفر."

    action, symbol_key = mapping[cmd]
    symbol = SYMBOLS[symbol_key]

    if qty > symbol["max_qty"]:
        return None, f"الكمية أكبر من الحد الآمن: {symbol['max_qty']}kg"

    order = {
        "action": action,
        "symbol_key": symbol_key,
        "security_id": symbol["security_id"],
        "currency": symbol["currency"],
        "qty": round(qty, 3),
        "limit_price": int(round(price)),
        "created_at": int(time.time()),
    }

    return order, None


def execute_pending_order():
    env = load_env()
    order = load_pending()

    if not order:
        return "لا يوجد أمر معلّق."

    username = env.get("BV_USERNAME")
    password = env.get("BV_PASSWORD")

    if not username or not password:
        return "❌ بيانات BullionVault غير موجودة في .env"

    api = BullionVaultAPI(username, password)

    resp = api.place_order(
        action=order["action"],
        security_id=order["security_id"],
        currency=order["currency"],
        quantity=order["qty"],
        limit=order["limit_price"],
        type_code="TIL_CANCEL",
        client_ref=f"MANUAL{int(time.time())}",
    )

    clear_pending()

    if resp is None:
        return "❌ فشل تنفيذ الأمر. لم يصل رد صحيح من BullionVault."

    return (
        "✅ Manual order sent to BullionVault\n"
        f"Action: {order['action']}\n"
        f"Security: {order['security_id']}/{order['currency']}\n"
        f"Qty: {order['qty']}kg\n"
        f"Limit: {order['limit_price']}"
    )


def positions_report():
    report = "📦 OPEN POSITIONS\n\n"
    found = False

    for key, symbol in SYMBOLS.items():
        log_file = symbol["log"]
        if not log_file.exists():
            continue

        lines = log_file.read_text(
            encoding="utf-8",
            errors="ignore"
        ).splitlines()[-300:]

        latest = None
        for line in reversed(lines):
            if "مركز |" in line:
                latest = line
                break

        if latest:
            found = True
            report += f"{symbol['icon']} {symbol['name']}\n{latest}\n\n"

    if not found:
        report += "No open positions"

    return report


def main():
    env = load_env()
    token = env.get("TG_TOKEN_SILVER") or env.get("TG_TOKEN_PALLADIUM")
    chat_id = str(env.get("TG_CHAT_ID", "")).strip()

    if not token or not chat_id:
        raise SystemExit("Missing Telegram token or chat id")

    send(token, chat_id, "✅ Guardian Telegram Command Center started")

    offset = None

    while True:
        try:
            data = get_updates(token, offset)

            for item in data.get("result", []):
                offset = item["update_id"] + 1
                msg = item.get("message") or {}
                incoming_chat = str((msg.get("chat") or {}).get("id", ""))

                if incoming_chat != chat_id:
                    continue

                text = (msg.get("text") or "").strip().lower()
                state = load_state()

                if text == "/status":
                    send(token, chat_id, "📊 STATUS\n" + json.dumps(state, indent=2))

                elif text == "/positions":
                    send(token, chat_id, positions_report())

                elif text == "/pause":
                    state["paused"] = True
                    save_state(state)
                    send(token, chat_id, "⏸️ Bot paused")

                elif text == "/resume":
                    state["paused"] = False
                    save_state(state)
                    send(token, chat_id, "▶️ Bot resumed")

                elif text == "/no_buy":
                    state["allow_buy"] = False
                    save_state(state)
                    send(token, chat_id, "🛑 BUY disabled")

                elif text == "/allow_buy":
                    state["allow_buy"] = True
                    save_state(state)
                    send(token, chat_id, "✅ BUY enabled")

                elif text == "/no_sell":
