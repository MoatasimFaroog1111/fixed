                        if isinstance(market, list):
                            market = {
                                item.get("security_id") or item.get("id") or item.get("symbol") or item.get("security"): item
                                for item in market
                                if isinstance(item, dict)
                            }

                        name_map = {
                            "AGXLN": "Silver",
                            "AUXLN": "Gold",
                            "PTXLN": "Platinum",
                            "PDXLN": "Palladium",
                        }

                        usd = float(bal.get("USD", {}).get("available", 0) or 0)
                        gbp = float(bal.get("GBP", {}).get("available", 0) or 0)
                        eur = float(bal.get("EUR", {}).get("available", 0) or 0)

                        if text == "/balance":
                            msg = (
