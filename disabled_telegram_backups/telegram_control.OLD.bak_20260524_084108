                    save_state(state)
                    send(token, chat_id, "🛑 SELL disabled")

                elif text == "/allow_sell":
                    state["allow_sell"] = True
                    save_state(state)
                    send(token, chat_id, "✅ SELL enabled")

                elif text == "/no_silver":
                    state["silver_enabled"] = False
                    save_state(state)
                    send(token, chat_id, "🛑 Silver disabled")

                elif text == "/allow_silver":
                    state["silver_enabled"] = True
                    save_state(state)
                    send(token, chat_id, "✅ Silver enabled")

                elif text == "/no_palladium":
                    state["palladium_enabled"] = False
                    save_state(state)
                    send(token, chat_id, "🛑 Palladium disabled")

                elif text == "/allow_palladium":
                    state["palladium_enabled"] = True
                    save_state(state)
                    send(token, chat_id, "✅ Palladium enabled")

                elif text == "/close_all":
                    state["emergency_close_all"] = True
