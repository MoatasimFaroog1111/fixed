                                lines = f.readlines()[-10:]
                        except:
                            pass

                        if not lines:
                            send(token, chat_id, "📜 لا يوجد سجل تداول بعد")
                            continue

                        msg = "📜 آخر الصفقات\n\n"

                        for line in reversed(lines):
                            try:
                                d = json.loads(line)

                                msg += (
                                    f"{d.get('action')} "
                                    f"{d.get('symbol')} "
                                    f"{d.get('qty')}kg @ "
                                    f"{d.get('price')}\n"
                                )

                            except:
                                pass

                        send(token, chat_id, msg)

                    except Exception as e:
                        send(token, chat_id, f"❌ History error: {e}")


elif text in ("/portfolio", "/balance", "/inventory"):
                    try:
                        import os
